# Database (PostGIS)
DATABASE_URL=postgresql://fuelmap:fuelmap@localhost:5433/fuelmap

# Valhalla routing engine
VALHALLA_URL=http://localhost:8002

# Photon geocoding
PHOTON_URL=http://localhost:2322

# Tile provider
NEXT_PUBLIC_TILE_URL=https://tiles.openfreemap.org/styles/liberty/{z}/{x}/{y}.pbf

# Country scrapers
TANKERKOENIG_API_KEY=your-tankerkoenig-api-key

# MaxMind GeoLite2 (for IP-based country detection)
MAXMIND_LICENSE_KEY=your-maxmind-license-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=es
NEXT_PUBLIC_DEFAULT_FUEL_TYPE=B7
