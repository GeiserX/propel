# =============================================================================
# Pumperly — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# See AGENTS.md "Environment Variables" section for full documentation.
# =============================================================================

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# PostGIS connection string
DATABASE_URL=postgresql://propel:propel@localhost:5433/propel

# ---------------------------------------------------------------------------
# App Configuration
# ---------------------------------------------------------------------------

# ISO 3166-1 alpha-2 code for initial map view (default: ES)
# Supported: ES, FR, DE, IT, GB, AT, PT, SI, NL, BE, LU, RO, GR, IE, HR
PUMPERLY_DEFAULT_COUNTRY=ES

# Comma-separated ISO codes to enable (default: all countries with scrapers)
# Example: ES,FR,DE — limits the app to only those countries
# PUMPERLY_ENABLED_COUNTRIES=ES,FR,PT,IT,AT,DE,GB,SI,NL,BE,LU,RO,GR,IE,HR

# Override default fuel type (default: per-country, e.g. B7 for Spain)
# See src/types/fuel.ts for valid codes
# PUMPERLY_DEFAULT_FUEL=B7

# Enable station clustering at low zoom levels (default: true)
# Set to false to always show individual station points
# PUMPERLY_CLUSTER_STATIONS=true

# Station search corridor width in km for route planning (default: 5, range: 0.5-50)
# PUMPERLY_CORRIDOR_KM=5

# Price sanity bounds for scraper validation (EUR/GBP/CHF per litre)
# Prices outside this range are rejected as bad data. Other currencies use 25x max.
# PUMPERLY_PRICE_MIN=0.30
# PUMPERLY_PRICE_MAX=4.00

# ---------------------------------------------------------------------------
# Scraper Schedule
# ---------------------------------------------------------------------------

# Automatic scraping interval in hours (default: 24)
# Runs once on startup + repeats on this interval. Set to 0 to disable.
# PUMPERLY_SCRAPE_INTERVAL_HOURS=24

# ---------------------------------------------------------------------------
# External Services (optional — only needed when those features are enabled)
# ---------------------------------------------------------------------------

# Valhalla self-hosted routing engine
# VALHALLA_URL=http://localhost:8002

# Photon geocoding / address autocomplete
# PHOTON_URL=http://localhost:2322

# ---------------------------------------------------------------------------
# Scraper API Keys (only needed for running scrapers)
# ---------------------------------------------------------------------------

# Germany (Tankerkoenig) — free API key from creativecommons.tankerkoenig.de
# TANKERKOENIG_API_KEY=your-tankerkoenig-api-key

# OpenChargeMap — EV charging station data (free key from openchargemap.org)
# PUMPERLY_OCM_API_KEY=your-ocm-api-key

# Set to 0 to disable EV charger scraping (default: enabled)
# PUMPERLY_EV_ENABLED=1

# ---------------------------------------------------------------------------
# Future (not yet implemented)
# ---------------------------------------------------------------------------

# MaxMind GeoLite2 license key (for IP-based country detection)
# MAXMIND_LICENSE_KEY=your-maxmind-license-key
